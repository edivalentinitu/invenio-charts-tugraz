exclude .editorconfig
exclude .tx/config
exclude pytest.ini
include *.rst
include babel.ini
include LICENSE
include *.yml
include run-js-linter.sh
include run-tests.sh
prune docs/_build
prune docs/_build
prune tests
recursive-include .github/workflows *.yml
recursive-include docs *.bat
recursive-include docs *.py
recursive-include docs *.rst
recursive-include docs *.txt
recursive-include docs Makefile
recursive-include invenio_charts_tugraz *.html *.jinja
recursive-include invenio_charts_tugraz *.js
recursive-include invenio_charts_tugraz *.json
recursive-include invenio_charts_tugraz *.less
recursive-include invenio_charts_tugraz *.mo
recursive-include invenio_charts_tugraz *.po
recursive-include invenio_charts_tugraz *.pot
recursive-include invenio_charts_tugraz *.py
include .git-blame-ignore-revs
